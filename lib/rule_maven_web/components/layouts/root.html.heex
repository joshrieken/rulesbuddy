<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Rule Maven" suffix=" · Rule Maven" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link rel="manifest" href={~p"/manifest.json"} />
    <link rel="apple-touch-icon" href={~p"/images/icon-192.svg"} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <script>
      (function() {
        var html = document.documentElement;
        var saved = localStorage.getItem('theme');
        if (saved) {
          html.setAttribute('data-theme', saved);
        } else {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          html.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      })();
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix.js"}>
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix_html.js"}>
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix_live_view.js"}
    >
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <div class="phx-disconnected-text">Lost connection. Retrying...</div>
    <div class="app-shell">
      <header class="header">
        <div class="header-inner">
          <a href={~p"/"} class="header-brand">
            <span class="header-icon">🎲</span>
            <span class="header-title">Rule <span class="header-title-accent">Maven</span></span>
          </a>

          <% me =
            assigns[:current_user] || (assigns[:conn] && assigns[:conn].assigns[:current_user]) ||
              (assigns[:conn] && RuleMavenWeb.Layouts.current_user(assigns[:conn])) %>

          <%= if me && RuleMaven.Users.game_master?(me) do %>
            <button class="hamburger" id="hamburger-btn" aria-label="Menu">
              <span></span><span></span><span></span>
            </button>
          <% end %>

          <!-- Desktop nav -->
          <nav class="header-nav" id="header-nav">
            <%= if me && RuleMaven.Users.game_master?(me) do %>
              <.link href={~p"/admin"} class="nav-link">Dashboard</.link>
              <.link href={~p"/admin/questions"} class="nav-link">Questions</.link>
              <.link href={~p"/admin/security"} class="nav-link">Security</.link>
              <.link href={~p"/admin/threads"} class="nav-link">Threads</.link>
              <.link href={~p"/admin/users"} class="nav-link">Users</.link>
              <.link href={~p"/admin/invites"} class="nav-link">Invites</.link>
              <.link href={~p"/admin/db"} class="nav-link nav-link-dim">DB</.link>
              <.link href={~p"/oban"} class="nav-link nav-link-dim" target="_blank">Oban</.link>
            <% end %>
          </nav>

          <div class="header-right">
            <div class="header-controls">
              <select class="theme-select" id="theme-select" aria-label="Theme">
                <option value="ocean">Abyss</option>
                <option value="arcade">Arcade</option>
                <option value="brass">Brass</option>
                <option value="forest">Canopy</option>
                <option value="retro">Cassette</option>
                <option value="coral">Coral</option>
                <option value="scary">Crypt</option>
                <option value="sunset">Dusk</option>
                <option value="ember">Ember</option>
                <option value="frost">Frost</option>
                <option value="happy">Golden Hour</option>
                <option value="honey">Honey</option>
                <option value="light">Lavender</option>
                <option value="marble">Marble</option>
                <option value="meadow">Meadow</option>
                <option value="dark">Midnight</option>
                <option value="scifi">Nebula</option>
                <option value="matrix">Neon</option>
                <option value="fantasy">Parchment</option>
                <option value="twilight">Twilight</option>
                <option value="void">Void</option>
              </select>
            </div>

            <%= cond do %>
              <% me -> %>
                <details class="user-dropdown">
                  <summary class="user-dropdown-toggle">
                    <span class="header-user">
                      {me.username}
                      <span
                        :if={RuleMaven.Users.game_master?(me)}
                        style="font-size:0.6rem;background:var(--accent);color:#fff;padding:0.1rem 0.35rem;border-radius:0.25rem;margin-left:0.3rem;font-weight:700;vertical-align:middle"
                      >GM</span>
                    </span>
                  </summary>
                  <div class="user-dropdown-menu">
                    <.link href={~p"/settings"} class="user-dropdown-link">Settings</.link>
                    <.link href={~p"/logout"} class="user-dropdown-link">Log out</.link>
                  </div>
                </details>
              <% true -> %>
                <.link href={~p"/register"} class="nav-link" style="color:var(--text-muted)">Register</.link>
                <.link href={~p"/login"} class="nav-link">Log in</.link>
            <% end %>
          </div>
        </div>
      </header>

      <!-- Mobile drawer overlay -->
      <div class="drawer-overlay" id="drawer-overlay"></div>
      <div class="drawer" id="drawer">
        <div class="drawer-header">
          <span class="drawer-title">Menu</span>
          <button class="drawer-close" id="drawer-close" aria-label="Close menu">&times;</button>
        </div>
        <nav class="drawer-nav">
          <.link href={~p"/"} class="drawer-link">🏠 Home</.link>
          <%= if me && RuleMaven.Users.game_master?(me) do %>
            <div class="drawer-section">Admin</div>
            <.link href={~p"/admin"} class="drawer-link">Dashboard</.link>
            <.link href={~p"/admin/questions"} class="drawer-link">Questions</.link>
            <.link href={~p"/admin/security"} class="drawer-link">Security</.link>
            <.link href={~p"/admin/db"} class="drawer-link">DB Admin</.link>
            <.link href={~p"/admin/threads"} class="drawer-link">Review Threads</.link>
            <.link href={~p"/admin/users"} class="drawer-link">Manage Users</.link>
            <.link href={~p"/admin/invites"} class="drawer-link">Invite Codes</.link>
            <div class="drawer-section">Tools</div>
            <.link href={~p"/oban"} class="drawer-link" target="_blank">Oban Dashboard ↗</.link>
            <.link href={~p"/settings"} class="drawer-link">Settings</.link>
          <% end %>
          <div class="drawer-section"></div>
          <%= if me do %>
            <.link href={~p"/logout"} class="drawer-link">Log out</.link>
          <% else %>
            <.link href={~p"/login"} class="drawer-link">Log in</.link>
            <.link href={~p"/register"} class="drawer-link">Register</.link>
          <% end %>
        </nav>
      </div>

      <.flash_group flash={assigns[:flash] || %{}} />

      <main class="main-content">
        <div class="container">
          {@inner_content}
        </div>
      </main>
    </div>

    <script>
      (function() {
        var select = document.getElementById('theme-select');
        var html = document.documentElement;

        function apply(value) {
          html.setAttribute('data-theme', value);
          localStorage.setItem('theme', value);
          select.value = value;
        }

        var saved = localStorage.getItem('theme');
        if (saved) {
          html.setAttribute('data-theme', saved);
          select.value = saved;
        } else {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = prefersDark ? 'dark' : 'light';
          html.setAttribute('data-theme', theme);
          select.value = theme;
        }

        select.addEventListener('change', function() {
          apply(this.value);
        });
      })();
    </script>
  </body>
</html>
