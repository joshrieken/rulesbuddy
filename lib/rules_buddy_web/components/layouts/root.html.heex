<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Rules Buddy" phx-no-format>{assigns[:page_title] || "Rules Buddy"}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link rel="manifest" href={~p"/manifest.json"} />
    <link rel="apple-touch-icon" href={~p"/images/icon-192.svg"} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <script>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        } else {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      })();
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix.js"}>
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix_html.js"}>
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix_live_view.js"}
    >
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <div class="app-shell">
      <header class="header">
        <div class="header-inner">
          <a href={~p"/"} class="header-brand">
            <span class="header-icon">◆</span>
            <span class="header-title">Rules Buddy</span>
          </a>
          <span class="header-tagline">board game rules assistant</span>

          <div class="header-auth">
            <% me =
              assigns[:current_user] || (assigns[:conn] && assigns[:conn].assigns[:current_user]) ||
                (assigns[:conn] && RulesBuddyWeb.Layouts.current_user(assigns[:conn])) %>

            <%= cond do %>
              <% me && RulesBuddy.Users.game_master?(me) -> %>
                <span class="header-user">{me.username}</span>
                <span class="header-role-badge header-role-badge-gm">GM</span>
                <.link href={~p"/logout"} class="header-auth-link">Log out</.link>
              <% me -> %>
                <span class="header-user">{me.username}</span>
                <span class="header-role-badge header-role-badge-player">Player</span>
                <.link href={~p"/logout"} class="header-auth-link">Log out</.link>
              <% true -> %>
                <.link href={~p"/login"} class="header-auth-link">Log in</.link>
            <% end %>
          </div>

          <div class="header-controls">
            <select class="theme-select" id="theme-select" aria-label="Choose theme">
              <option value="light">Lavender</option>
              <option value="dark">Midnight</option>
              <option value="matrix">Neon</option>
              <option value="fantasy">Parchment</option>
              <option value="scifi">Nebula</option>
              <option value="scary">Crypt</option>
              <option value="happy">Golden Hour</option>
              <option value="forest">Canopy</option>
              <option value="ocean">Abyss</option>
              <option value="sunset">Dusk</option>
              <option value="retro">Cassette</option>
            </select>
          </div>
        </div>
      </header>

      <.flash_group flash={assigns[:flash] || %{}} />

      <main class="main-content">
        <div class="container">
          {@inner_content}
        </div>
      </main>
    </div>

    <script>
      (function() {
        var select = document.getElementById('theme-select');
        var html = document.documentElement;

        function apply(value) {
          html.setAttribute('data-theme', value);
          localStorage.setItem('theme', value);
          select.value = value;
        }

        var saved = localStorage.getItem('theme');
        if (saved) {
          html.setAttribute('data-theme', saved);
          select.value = saved;
        } else {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = prefersDark ? 'dark' : 'light';
          html.setAttribute('data-theme', theme);
          select.value = theme;
        }

        select.addEventListener('change', function() {
          apply(this.value);
        });
      })();
    </script>
  </body>
</html>
